# ============================================================
# RAG 服务配置示例 —— 复制为 .env 并按需修改
# 交付新项目时,90% 改动集中在本文件
# ============================================================

# ---------- 应用 ----------
APP_NAME=rag-service
ENVIRONMENT=dev            # dev | staging | prod
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json            # json(生产/便于采集) | console(本地/便于阅读)
HOST=0.0.0.0
PORT=8000

# ---------- 安全 ----------
# 多个 Key 用英文逗号分隔;生产环境务必配置,留空则不鉴权(仅限本地开发)
API_KEYS=
# CORS 允许来源,逗号分隔,* 表示全部
CORS_ORIGINS=*
# 上传文件大小上限(MB)
MAX_UPLOAD_MB=25

# ---------- 阿里百炼 / DashScope(LLM 与 Embedding 默认共用此密钥) ----------
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------- 大模型(LLM) ----------
# 留空 base_url/key 则回退到上面的 DASHSCOPE_* 配置
LLM_PROVIDER=openai_compat
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=qwen-plus        # qwen-plus / qwen-max / qwen-turbo 等
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2

# ---------- 向量化(Embedding) ----------
# openai_compat = 百炼/DashScope 等 OpenAI 兼容 API; tei = 本地 HuggingFace TEI 服务
EMBEDDING_PROVIDER=openai_compat
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024         # 维度必须与向量库集合一致;切换模型/维度需重建集合
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TIMEOUT=30
EMBEDDING_MAX_RETRIES=2

# 本地 TEI(text-embeddings-inference)服务,仅当 EMBEDDING_PROVIDER=tei 时生效
# 例:BAAI/bge-large-zh-v1.5 -> EMBEDDING_DIM=1024 / bge-base-zh-v1.5 -> 768 / bge-small -> 512
TEI_URL=http://localhost:8080
TEI_API_KEY=               # TEI 以 --api-key 启动时填写,否则留空
TEI_NORMALIZE=true         # 归一化向量(配合余弦距离)
TEI_TRUNCATE=true          # 超长输入由服务端截断,避免 413

# ---------- 向量数据库 ----------
VECTOR_STORE=qdrant        # qdrant | redis(Redis Stack: RediSearch+RedisJSON)
RETRIEVAL_TOP_K=5
SCORE_THRESHOLD=0.0        # 相似度阈值(余弦相似度 0~1),0 表示不过滤

# Qdrant(VECTOR_STORE=qdrant 时生效)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_documents

# Redis Stack(VECTOR_STORE=redis 时生效;需安装 redis-py: pip install redis)
REDIS_VECTOR_URL=redis://localhost:6379/0
REDIS_INDEX_NAME=rag_knowledge_index
REDIS_VECTOR_PREFIX=embedding:
REDIS_INDEX_TAGS=document_id,source,tenant   # 可用于 filters 过滤的字段(逗号分隔)

# ---------- 重排序(Rerank,默认关闭) ----------
RERANKER_ENABLED=false
RERANKER_PROVIDER=noop     # noop | dashscope
RERANKER_MODEL=gte-rerank-v2
RERANK_TOP_N=5

# ---------- 会话记忆 ----------
MEMORY_BACKEND=sqlite      # sqlite | memory | redis
SQLITE_PATH=./data/conversations.db
REDIS_URL=redis://localhost:6379/0
MAX_HISTORY_TURNS=10

# ---------- 文档分块 ----------
CHUNK_SIZE=800
CHUNK_OVERLAP=120
